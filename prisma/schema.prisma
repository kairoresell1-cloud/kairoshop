// Kairo Shop — Database Schema
// Fase 1: fondamenta reali. Moduli avanzati (BI, multilingua, return ecc.)
// si aggiungono come tabelle successive senza rompere questa base.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
  OWNER
  SUPER_OWNER
}

enum OrderStatus {
  DA_PREPARARE
  PREPARATO
  SPEDITO
  CONSEGNATO
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  role          Role      @default(USER)
  permissions   Permission[]
  totalSpent    Float     @default(0)
  ordersCount   Int       @default(0)
  customerLevel String    @default("Nuovo") // Nuovo, Attivo, VIP, Inattivo, Top
  adminNotes    String?
  banned        Boolean   @default(false)
  createdAt     DateTime  @default(now())
  orders        Order[]
  wishlist      WishlistItem[]
  auditLogs     AuditLog[]
  accounts      Account[]
  sessions      Session[]
}

// Modelli richiesti da NextAuth (PrismaAdapter) per gestire il login Google
// e le sessioni utente. Non vanno modificati.
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Permessi granulari assegnabili agli Admin (Owner/Super Owner li hanno tutti di default)
model Permission {
  id     String @id @default(cuid())
  key    String // es. PRODUCTS_EDIT, FINANCE_VIEW, SUPPLIERS_COSTS_VIEW
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  @@unique([userId, key])
}

model Category {
  id       String    @id @default(cuid())
  name     String    @unique
  slug     String    @unique
  products Product[]
}

model Product {
  id          String   @id @default(cuid())
  title       String
  description String
  images      String[] // gallery URLs
  basePrice   Float
  stock       Int      @default(0)
  tags        String[]
  badge       String?  // New, Bestseller, Offerta, Premium, Limited
  category    Category @relation(fields: [categoryId], references: [id])
  categoryId  String
  variants    ProductVariant[]
  bulkPrices  BulkPrice[]
  supplierLinks ProductSupplier[]
  createdAt   DateTime @default(now())
  orderItems  OrderItem[]
  wishlistedBy WishlistItem[]
}

model ProductVariant {
  id        String  @id @default(cuid())
  colorName String
  colorHex  String
  stock     Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
}

model BulkPrice {
  id        String  @id @default(cuid())
  minQty    Int
  price     Float
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
}

model StockReservation {
  id           String   @id @default(cuid())
  productId    String
  variantId    String?
  quantity     Int
  sessionToken String
  expiresAt    DateTime
  createdAt    DateTime @default(now())
}

// Il codice che il cliente genera al checkout. NON è un ordine reale —
// è solo un "pacchetto" che il cliente invia privatamente. Diventa un
// vero Order solo quando l'Owner lo converte manualmente.
model OrderCode {
  id          String   @id @default(cuid())
  code        String   @unique
  userId      String?
  items       Json
  subtotal    Float
  shippingFee Float
  total       Float
  converted   Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Order {
  id            String      @id @default(cuid())
  code          String      @unique // formato KS-XXXX-XXXX
  user          User?       @relation(fields: [userId], references: [id])
  userId        String?
  items         OrderItem[]
  subtotal      Float
  shippingFee   Float
  total         Float
  status        OrderStatus @default(DA_PREPARARE)
  customerName  String?
  customerSurname String?
  customerStreet String?
  customerStreetNumber String?
  customerCity  String?
  customerZip   String?
  customerPhone String?
  trackingCarrier String?
  trackingCode    String?
  labels        String[]    // VIP, Urgente, Problema, Reso...
  createdAt     DateTime    @default(now())
}

model OrderItem {
  id        String  @id @default(cuid())
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   String
  product   Product @relation(fields: [productId], references: [id])
  productId String
  variantName String?
  quantity  Int
  unitPrice Float
}

model Coupon {
  id            String   @id @default(cuid())
  code          String   @unique
  percentOff    Float?
  fixedOff      Float?
  expiresAt     DateTime?
  usageLimit    Int?
  usedCount     Int      @default(0)
  active        Boolean  @default(true)
}

model Promotion {
  id        String   @id @default(cuid())
  type      String   // PRODUCT_DISCOUNT, QTY_DISCOUNT, CART_DISCOUNT, FREE_SHIPPING
  active    Boolean  @default(true)
  startsAt  DateTime?
  endsAt    DateTime?
  rules     Json
}

model WishlistItem {
  id        String  @id @default(cuid())
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String

  @@unique([userId, productId])
}

model Supplier {
  id       String   @id @default(cuid())
  name     String
  contact  String?
  notes    String?
  status   String   @default("Attivo")
  products ProductSupplier[]
}

model ProductSupplier {
  id         String   @id @default(cuid())
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId  String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  supplierId String
  costPrice  Float
  isPrimary  Boolean  @default(false)
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  before    Json?
  after     Json?
  user      User?    @relation(fields: [userId], references: [id])
  userId    String?
  createdAt DateTime @default(now())
}
